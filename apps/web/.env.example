# Local development.
#
# `npm run dev` proxies /api/* to whatever VITE_API_URL points at.
# Three common setups:
#
#   1. Local SAM (recommended while iterating on backend changes):
#        cd ~/career-jump-aws
#        sam local start-api --port 3000
#      Then leave VITE_API_URL unset (or = http://localhost:3000).
#
#   2. Live AWS dev/poc API (no Docker needed):
#        VITE_API_URL=https://<api-id>.execute-api.us-east-1.amazonaws.com/Prod
#
#   3. Behind Lambda function URL:
#        VITE_API_URL=https://<lambda-fn-url>.lambda-url.us-east-1.on.aws
VITE_API_URL=http://localhost:3000

# Local-only demo/mock mode. Keep this false or unset for production builds.
VITE_USE_MOCKS=false

# Isolated AWS backend/auth values. Production can also inject these at runtime
# through public/aws-config.js so the static bundle does not need a rebuild.
VITE_AWS_REGION=us-east-1
VITE_API_BASE_URL=
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_APP_CLIENT_ID=
VITE_COGNITO_DOMAIN=
