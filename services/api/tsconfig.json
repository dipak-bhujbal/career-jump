{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["ES2022"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "worker-configuration.d.ts", "*.json"]
}